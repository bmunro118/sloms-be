{
  "$schema": "https://swc.rs/schema.json",
  "sourceMaps": "inline",
  "module": { "type": "commonjs", "importInterop": "none" },
  "jsc": {
    "target": "es2021",
    "keepClassNames": true,
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true
    }
  }
}
