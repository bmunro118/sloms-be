{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "@swc/jest"
  },
  "transformIgnorePatterns": ["/node_modules/(?!(otplib|@otplib|@scure|@noble)/)"],
  "testTimeout": 30000,
  "maxWorkers": 1,
  "globalSetup": "<rootDir>/support/global-setup.js",
  "testSequencer": "<rootDir>/support/sequencer.js"
}
