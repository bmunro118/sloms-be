# Production config template. Copy to `.env.prod` (gitignored) and fill in real
# values, or source these from your secret store / CI variables at deploy time.
# Do NOT commit a populated .env.prod.
NODE_ENV=production
DATABASE_URL=postgresql://<user>:<password>@sloms-postgres.postgres.database.azure.com/slomsdb?sslmode=require
PGHOST=sloms-postgres.postgres.database.azure.com
PGPORT=5432
PGUSER=<user>
JWT_SECRET=<generate-a-strong-random-secret>
JWT_EXPIRES_IN=8h
# Base URL of the customer web portal, used in onboarding welcome emails.
PORTAL_URL=https://portal.soniclabs.co.uk
# Azure Communication Services — required to actually send outbound email
# (welcome emails, 2FA codes). When unset, emails are logged instead of sent.
ACS_CONNECTION_STRING=<acs-connection-string>
ACS_SENDER_ADDRESS=DoNotReply@<guid>.azurecomm.net
